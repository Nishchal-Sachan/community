# =============================================================================
# Copy to `.env` or `.env.local` and fill in values. Never commit real secrets.
# Next.js loads `.env`, `.env.local`, etc. from the project root (next to next.config).
# Variable names below match `process.env.*` usage in this repository exactly.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER CONFIG
# -----------------------------------------------------------------------------

# Runtime mode. Next.js sets this during `next dev` / `next build` / `next start`.
# Used for secure cookies (HTTPS-only) in production.
NODE_ENV=

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Primary MongoDB connection string (preferred). Used by Mongoose in `lib/db.ts`.
# Example: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE_NAME
DATABASE_URL=

# Alternate MongoDB URI if `DATABASE_URL` is unset. Same format as above.
# Used by `lib/db.ts` and seed scripts (`scripts/seed-admin.ts`, `scripts/seed-member.ts`).
MONGODB_URI=

# -----------------------------------------------------------------------------
# AUTH / JWT
# -----------------------------------------------------------------------------

# Secret for signing admin and member JWTs (cookies: admin_token, auth_token).
# Required at startup. Use a long random string in production (e.g. openssl rand -base64 32).
JWT_SECRET=

# Note: Access token expiry is hardcoded to 7 days in `lib/auth.ts` and `lib/user-auth.ts`
# (no separate JWT_EXPIRES_IN env var in this project).

# -----------------------------------------------------------------------------
# EMAIL — single Nodemailer transporter (`services/emailService.ts`)
# Payment receipts + helpdesk notifications. See `lib/send-payment-receipt-email.ts`, `lib/helpdesk-mail.ts`.
# -----------------------------------------------------------------------------

# Use Gmail App Password (not normal password)
# https://support.google.com/accounts/answer/185833

# SMTP sender (used for auth and as default "From" for all outbound mail).
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Helpdesk: notifications are sent TO this address (not used for SMTP login).
ADMIN_EMAIL=admin_email@gmail.com

# Optional legacy SMTP login if EMAIL_* unset.
SMTP_USER=
SMTP_PASS=

# Set to "true" for TLS on port 465; leave empty/false for STARTTLS on 587.
SMTP_SECURE=

# Payment receipt From: override (optional; defaults to EMAIL_USER).
SMTP_FROM=

# -----------------------------------------------------------------------------
# PAYMENT GATEWAY (Razorpay)
# -----------------------------------------------------------------------------

# Razorpay Key ID (public key, safe to expose to client flows that need it).
# Used by `app/api/payment/*` and `app/api/marriage/subscribe` / `verify`.
RAZORPAY_KEY_ID=

# Razorpay Key Secret (server-only; never expose to the browser).
RAZORPAY_SECRET=

# -----------------------------------------------------------------------------
# CLIENT / FRONTEND (NEXT_PUBLIC_* — embedded in the browser bundle; not for secrets)
# -----------------------------------------------------------------------------

# Absolute origin of the app for server-side fetches to this deployment (no trailing slash).
# Used by `lib/get-app-base-url.ts` when building URLs to your own API.
# Example: http://localhost:3000  |  https://www.example.org
NEXT_PUBLIC_API_URL=

# Same purpose as above; checked after NEXT_PUBLIC_API_URL if that is empty.
NEXT_PUBLIC_APP_URL=

# Same purpose as above; third fallback in `getAppBaseUrl()`.
NEXT_PUBLIC_BASE_URL=

# Organisation / site display name (metadata, titles). Optional; code has a default if empty.
NEXT_PUBLIC_APP_NAME=

# -----------------------------------------------------------------------------
# HOSTING (optional — usually injected by the platform)
# -----------------------------------------------------------------------------

# Vercel sets this automatically on Vercel deployments. Used by `get-app-base-url.ts`
# when public URL env vars above are not set.
VERCEL_URL=

# -----------------------------------------------------------------------------
# FILE UPLOAD (Cloudinary)
# -----------------------------------------------------------------------------

# Cloudinary cloud name from the dashboard.
CLOUDINARY_CLOUD_NAME=

# Cloudinary API key (server-side uploads: admin site content, matrimony photos, etc.).
CLOUDINARY_API_KEY=

# Cloudinary API secret (server-only).
CLOUDINARY_API_SECRET=
