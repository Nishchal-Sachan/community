# =============================================================================
# Environment variables — copy to `.env.local` and fill in real values.
# Never commit `.env`, `.env.local`, or any file containing secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Public (NEXT_PUBLIC_* — embedded in the client bundle; not for secrets)
# -----------------------------------------------------------------------------

# Base URL of this application, used when the server calls your own API routes
# (e.g. RSC/SSR fetch to /api/*). No trailing slash.
# Examples: http://localhost:3000  |  https://www.example.org
# Leave empty on Vercel/local dev to fall back to VERCEL_URL or request headers.
NEXT_PUBLIC_API_URL=

# Display name for the organisation (metadata, titles, future UI).
NEXT_PUBLIC_APP_NAME=Akhil Bhartiya Kushwaha Mahasabha

# -----------------------------------------------------------------------------
# Server-only (never expose to the browser; keep out of git)
# -----------------------------------------------------------------------------

# Primary database connection string. For this project: MongoDB URI for Mongoose.
# Example: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/dbname
# If you previously used MONGODB_URI, that variable still works when DATABASE_URL is unset.
DATABASE_URL=

# Secret key for signing and verifying admin JWT session cookies. Use a long,
# random string in production (e.g. openssl rand -base64 32).
JWT_SECRET=

# -----------------------------------------------------------------------------
# Razorpay (for membership payment)
# -----------------------------------------------------------------------------
# From Razorpay Dashboard: Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# -----------------------------------------------------------------------------
# Cloudinary (for profile photo uploads)
# -----------------------------------------------------------------------------
# From Cloudinary Dashboard: Account → API Keys
# Used for matrimony profile photos — stores only URLs in DB, not image data
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
